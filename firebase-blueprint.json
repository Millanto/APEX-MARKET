{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and profile details registered in the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user authentication ID." },
        "name": { "type": "string", "minLength": 2, "maxLength": 100 },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string", "maxLength": 20 },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string" },
        "lastLogin": { "type": "string" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Commercial product item catalog details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "minLength": 2, "maxLength": 150 },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "discount": { "type": "number" },
        "oldPrice": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "stock": { "type": "number" },
        "description": { "type": "string" },
        "specifications": { "type": "object" },
        "features": { "type": "array" },
        "images": { "type": "array" }
      },
      "required": ["id", "name", "category", "price", "stock", "images"]
    },
    "Category": {
      "title": "Category",
      "description": "E-commerce product hierarchy category.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["id", "name", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "E-commerce order placed by an authenticated user.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "shippingAddress": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "subtotal": { "type": "number" },
        "tax": { "type": "number" },
        "shipping": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string" }
      },
      "required": ["orderId", "userId", "items", "shippingAddress", "paymentMethod", "total", "status", "createdAt"]
    },
    "Wishlist": {
      "title": "Wishlist Item",
      "description": "Product saved to wishlist by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "productId", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "User rating and comment left on a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "productId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "productId", "rating", "comment", "createdAt"]
    },
    "Address": {
      "title": "Saved Address",
      "description": "Shipping or billing address saved by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "label": { "type": "string" },
        "fullName": { "type": "string" },
        "street": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zipCode": { "type": "string" },
        "country": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["id", "userId", "fullName", "street", "city", "state", "zipCode", "country", "phone"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users profile collection key-value maps."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Catalog of commercial items."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Catalog categories available."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Secure orders placed by customers."
    },
    "/wishlist/{wishlistId}": {
      "schema": { "$ref": "#/entities/Wishlist" },
      "description": "User wishlists."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "User ratings and written product feedback."
    },
    "/addresses/{addressId}": {
      "schema": { "$ref": "#/entities/Address" },
      "description": "User saved physical mailing addresses."
    }
  }
}
