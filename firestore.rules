rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // Phase 1: Catch-All Default Deny Rule
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // Phase 3: Global Hardened Helpers
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ==========================================
    // Entity Schema Validation Helpers
    // ==========================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt'])
        && data.uid == request.auth.uid
        && data.email is string
        && data.email.size() <= 200
        && (data.get('phone', '') is string && data.get('phone', '').size() <= 30)
        && (data.get('name', '') is string && data.get('name', '').size() <= 150)
        && (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 1000);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'price', 'stock', 'images'])
        && data.id is string
        && data.name is string
        && data.name.size() <= 200
        && data.category is string
        && data.price is number
        && data.price >= 0
        && data.stock is number
        && data.stock >= 0
        && data.images is list;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['orderId', 'userId', 'items', 'shippingAddress', 'paymentMethod', 'total', 'status', 'createdAt'])
        && data.orderId is string
        && data.userId == request.auth.uid
        && data.items is list
        && data.items.size() > 0
        && data.shippingAddress is map
        && data.paymentMethod is string
        && data.total is number
        && data.total >= 0
        && data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'userId', 'userName', 'productId', 'rating', 'comment', 'createdAt'])
        && data.id is string
        && data.userId == request.auth.uid
        && data.userName is string
        && data.userName.size() <= 150
        && data.productId is string
        && data.rating is number
        && data.rating >= 1
        && data.rating <= 5
        && data.comment is string
        && data.comment.size() <= 2000;
    }

    function isValidAddress(data) {
      return data.keys().hasAll(['id', 'userId', 'fullName', 'street', 'city', 'state', 'zipCode', 'country', 'phone'])
        && data.id is string
        && data.userId == request.auth.uid
        && data.fullName is string
        && data.fullName.size() <= 150
        && data.street is string
        && data.street.size() <= 300
        && data.city is string
        && data.city.size() <= 100
        && data.state is string
        && data.state.size() <= 100
        && data.zipCode is string
        && data.zipCode.size() <= 20
        && data.country is string
        && data.country.size() <= 100
        && data.phone is string
        && data.phone.size() <= 30;
    }

    function isValidWishlist(data) {
      return data.keys().hasAll(['id', 'userId', 'productId', 'createdAt'])
        && data.id is string
        && data.userId == request.auth.uid
        && data.productId is string;
    }

    // ==========================================
    // Collection Matching Rules
    // ==========================================

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt; // Immutability Guard
      allow delete: if isAdmin();
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Categories Collection
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin(); // Users cannot modify their orders once placed.
      allow delete: if isAdmin();
    }

    // Wishlist Collection
    match /wishlist/{wishlistId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidWishlist(incoming());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Reviews Collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Saved Addresses Collection
    match /addresses/{addressId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidAddress(incoming());
      allow update: if isSignedIn() && isValidAddress(incoming()) && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only configured via console or Cloud Functions.
    }
  }
}
